{
  "name": "ce-serverlist",
  "version": "1.0.0",
  "private": true,
  "description": "Gamespy master server replacement that only accounts for Codename Eagle",
  "keywords": [
    "codename",
    "codename-eagle",
    "eagle",
    "gamespy"
  ],
  "homepage": "https://github.com/rexxars/ce-serverlist#readme",
  "bugs": {
    "url": "https://github.com/rexxars/ce-serverlist/issues"
  },
  "license": "MIT",
  "author": "Espen Hovlandsdal <espen@hovlandsdal.com>",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/rexxars/ce-serverlist.git"
  },
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.ts | pino-pretty -l -t 'SYS: HH:MM:ss.l' -i 'pid,hostname'",
    "start": "node src/server.ts",
    "typecheck": "tsc",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "@sanity/client": "^7.22.1",
    "@sanity/diff-patch": "^6.0.0",
    "lru-cache": "^11.5.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=26.0.0"
  }
}
